{
  "name": "@hacksaw/crate",
  "version": "0.0.1",
  "description": "File-based routing CLI metaframework built on @bomb.sh/args",
  "keywords": [
    "cli",
    "framework",
    "routing",
    "typescript"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && rolldown --config rolldown.config.ts && tsc --emitDeclarationOnly",
    "dev": "rolldown --config rolldown.config.js --watch",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bomb.sh/args": "^0.3.1",
    "@standard-schema/spec": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "jiti": "^2.6.1",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "rolldown": "1.0.0-rc.13",
    "typescript": "^5.5.0",
    "zod": "4.3.6"
  }
}
